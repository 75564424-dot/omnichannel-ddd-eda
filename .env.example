APP_NAME="Platform Middleware Instance"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
# Must match APP_URL host (use 127.0.0.1, not localhost) for Vite + session cookies.
VITE_DEV_SERVER_URL=http://127.0.0.1:5173
# Local assets: npm run local (Vite + Laravel) | npm run build && npm run serve (compiled)
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug
# LOG_STACK=json
# Production cloud: LOG_STACK=stderr_json

# --- Platform instance identity (ADR-001: one instance = one client) ---
# Unique slug for this deployment (inventory, logs, tenant row).
PLATFORM_CLIENT_SLUG=acme-retail
PLATFORM_SIMULATION_ENABLED=true
PLATFORM_SIMULATION_FIXTURE_SLUG=acmepos
PLATFORM_CONTROL_PLANE_URL=http://127.0.0.1:8000
PLATFORM_SIMULATION_INTERNAL_TOKEN=local-dev-simulation-token
PLATFORM_CLIENT_NAME="Acme Retail Middleware"
PLATFORM_DEPLOYMENT_MODE=instance_per_client
# SaaS fleet registry (many tenants on this host). true on control-plane dev; false on each client silo.
PLATFORM_CONTROL_PLANE=false
# Demo only: login cross-tenant on same URL. false in production client instances.
PLATFORM_PORTAL_MULTI_TENANT_LOGIN=false
# Local dev: auto-create isolated instance (.env + SQLite) when provisioning a tenant on control plane
PLATFORM_LOCAL_FLEET_AUTO_PROVISION=false
PLATFORM_LOCAL_FLEET_PORT_START=8001
PLATFORM_LOCAL_FLEET_DEFAULT_ADMIN_PASSWORD=client-local-dev
PLATFORM_INSTANCE_URL_TEMPLATE=https://{slug}.middleware.example.com
PLATFORM_SEED_INSTANCE_TENANT=true

# --- Database ---
DB_CONNECTION=sqlite
# DB_DATABASE is auto-set to database/database.sqlite for sqlite

# MySQL (production recommended)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=platform_acme
# DB_USERNAME=platform
# DB_PASSWORD=

# --- Queue ---
QUEUE_CONNECTION=sync
# Production (Plan_Cloud): redis + worker container
# QUEUE_CONNECTION=redis

# --- Cache & sessions ---
CACHE_STORE=database
SESSION_DRIVER=database
# Local multi-port dev: unique per instance (see scripts/local-instances/lib.mjs).
# SESSION_COOKIE=platform_session_acme_retail
# SESSION_XSRF_COOKIE=platform_xsrf_acme_retail
# MODULES_CONFIG_PATH=config/modules/instances/acme-retail/modules_config.json
# Production (Plan_Cloud):
# CACHE_STORE=redis
# SESSION_DRIVER=redis

# --- Mail (optional) ---
MAIL_MAILER=log

# --- Cloud / Docker (Plan_Cloud) ---
# Production stack: docker compose up -d --build
APP_PUBLISH_PORT=8080
MYSQL_ROOT_PASSWORD=change-me
MYSQL_PUBLISH_PORT=3306
REDIS_PUBLISH_PORT=6379
# web | worker | scheduler (docker-compose worker/scheduler services)
DOCKER_APP_ROLE=web

# Redis (required when CACHE/QUEUE/SESSION use redis)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Production profile (uncomment for cloud deploy)
# APP_ENV=production
# APP_DEBUG=false
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=platform_middleware
# DB_USERNAME=platform
# DB_PASSWORD=
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis
# SESSION_DRIVER=redis

# Health probes: /up (liveness), /health/ready (DB + Redis when configured)

# --- Security (Plan_Seguridad) ---
# Enable API token/key auth on /api/middleware/* and /api/dashboard/*
PLATFORM_API_AUTH_ENABLED=true
# Static M2M keys: key|ability1,ability2;another|bus:admin
# Abilities: events:publish, bus:read, bus:admin, dashboard:read
PLATFORM_API_KEYS=
# Rate limits (requests per minute)
PLATFORM_RATE_LIMIT_PUBLISH=100
PLATFORM_RATE_LIMIT_SYNC=10
PLATFORM_RATE_LIMIT_STREAM=60
PLATFORM_RATE_LIMIT_DEFAULT=120
PLATFORM_SECURITY_HEADERS=true
PLATFORM_AUDIT_ENABLED=true
# Optional CSP override (default uses self-hosted fonts bundled by Vite)
# PLATFORM_HEADER_CSP=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data:; connect-src 'self'
# CORS allowlist (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
CORS_SUPPORTS_CREDENTIALS=false
# Sanctum (operator/session tokens — use platform:issue-api-token)
# Must include host:port used in the browser (e.g. 127.0.0.1:8000) or API session auth fails.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000,::1
SANCTUM_TOKEN_EXPIRATION=
# Optional JSON Schema validation on publish (per event_type in config/eventbus.php)
EVENTBUS_SCHEMA_VALIDATION=false

# --- Client simulation (Plan_SimulacionClientes) ---
# Enable demo pack listeners in eventbus (lab/staging only)
DEMO_PACK_ENABLED=false

# --- Database retention (Plan_BaseDeDatos) ---
# Override defaults in config/platform_retention.php
# RETENTION_MESSAGE_QUEUE_DAYS=30
# RETENTION_EVENT_LOGS_DAYS=30
# RETENTION_OBSERVABILITY_METRICS_DAYS=14
# RETENTION_EVENT_STORE_DAYS=90
# RETENTION_AUDIT_LOGS_DAYS=2555

# --- Event bus resilience (Plan_Resiliencia) ---
EVENTBUS_ASYNC_PROCESSING=false
EVENTBUS_ASYNC_LISTENERS=false
EVENTBUS_PROCESSING_TIMEOUT=30
EVENTBUS_CIRCUIT_BREAKER_ENABLED=false
EVENTBUS_CIRCUIT_BREAKER_FAILURES=5
EVENTBUS_CIRCUIT_BREAKER_OPEN_SECONDS=60

# --- Event bus middleware pipeline (Plan_Middleware) ---
EVENTBUS_DRIVER=laravel
EVENTBUS_OUTBOX_ENABLED=false
EVENTBUS_WORKFLOWS_ENABLED=false
# EVENTBUS_KAFKA_BROKERS=localhost:9092
# EVENTBUS_KAFKA_TOPIC=platform.events

# --- Integrations (Plan_Integraciones) ---
INTEGRATIONS_WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature
INTEGRATIONS_WEBHOOK_REQUIRE_SECRET=true

# --- Observability (Plan_Observabilidad) ---
PLATFORM_PROMETHEUS_ENABLED=true
PLATFORM_TRACE_SPANS_ENABLED=true
PLATFORM_OBSERVABILITY_SERVICE_NAME=
PLATFORM_SLO_BUS_LATENCY_P99_MS=2000
PLATFORM_SLO_DLQ_MAX=10
PLATFORM_SLO_FEED_LAG_P99_MS=3000
PLATFORM_SLO_SSE_MAX_CONNECTIONS=500

# --- Monitoring (Plan_Monitoreo) ---
PLATFORM_MONITORING_ENABLED=true
PLATFORM_CANARY_ENABLED=true
PLATFORM_CANARY_EVENT_TYPE=Platform.Monitoring.Canary
PLATFORM_CANARY_INTERVAL_MINUTES=5
PLATFORM_ALERT_ERROR_RATE_PERCENT=10
PLATFORM_ALERT_LATENCY_MS=2000
PLATFORM_ALERT_DLQ_MAX=10
PLATFORM_ALERT_BUS_STOPPED_MINUTES=5
PLATFORM_ALERT_DB_USAGE_PERCENT=80
PLATFORM_ALERT_QUEUE_DEPTH_MAX=1000
PLATFORM_DB_MAX_SIZE_MB=10240
PLATFORM_MONITOR_QUEUES=middleware,dashboard-feed,default
RETENTION_TRACE_LOGS_DAYS=14

# --- Quality (Plan_Calidad) ---
PLATFORM_QUALITY_COVERAGE_MIN=70
PLATFORM_LOAD_TEST_EPS=100
PLATFORM_LOAD_TEST_DURATION=60
PLATFORM_LOAD_TEST_MAX_ERROR_RATE=0.05
PLATFORM_LOAD_TEST_P95_MS=2000
PLATFORM_ZAP_BASELINE_ENABLED=true

# --- APIs (Plan_APIs) ---
PLATFORM_API_PROBLEM_DETAILS=true
PLATFORM_API_IDEMPOTENCY_ENABLED=true
PLATFORM_API_IDEMPOTENCY_TTL=86400
PLATFORM_API_DEFAULT_LIMIT=50
PLATFORM_API_MAX_LIMIT=200

# --- Authentication (Plan_Autenticacion) ---
PLATFORM_WEB_AUTH_ENABLED=true
PLATFORM_SEED_ADMIN_OPERATOR=true
PLATFORM_ADMIN_NAME="Platform Admin"
PLATFORM_ADMIN_EMAIL=admin@local
PLATFORM_ADMIN_PASSWORD=change-me-in-production
PLATFORM_ADMIN_ROLE=platform_admin

# SaaS control plane (your company — manages all client instances)
PLATFORM_SEED_SAAS_OPERATOR=true
PLATFORM_SAAS_ADMIN_NAME="SaaS Admin"
PLATFORM_SAAS_ADMIN_EMAIL=saas@local
PLATFORM_SAAS_ADMIN_PASSWORD=change-me-in-production
