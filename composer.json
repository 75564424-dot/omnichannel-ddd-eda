{
    "name": "platform/event-bus-core",
    "description": "Core platform: generic event bus middleware + observability dashboard (no business domains).",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "4.0",
        "opis/json-schema": "2.3",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/",
            "Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php scripts/apply-php85-laravel-pdo-mysql-fix.php"
        ],
        "test": "phpunit -c phpunit.xml",
        "lint": "pint --test app/Shared/Platform app/Console/Commands/ValidatePlatformCatalogCommand.php docs/testing/tools/validate_json_configs.php docs/testing/tools/sync_test_stats.php scripts/ci tests/Unit/Platform/ValidatePlatformCatalogTest.php",
        "analyse": "phpstan analyse --no-progress",
        "validate-config": [
            "@php docs/testing/tools/validate_json_configs.php",
            "@php artisan platform:validate-catalog"
        ],
        "validate-openapi": "bash scripts/ci/lint-openapi.sh",
        "test:stats": "@php docs/testing/tools/sync_test_stats.php",
        "test:stats:check": "@php docs/testing/tools/sync_test_stats.php --check",
        "test:docs": [
            "@php vendor/bin/phpunit --log-junit docs/testing/tools/last_junit.xml",
            "@php docs/testing/tools/generate_test_catalogs.php",
            "@php docs/testing/tools/export_test_matrix.php",
            "@php docs/testing/tools/export_strategic_csvs.php",
            "@php docs/testing/tools/generate_strategic_matrices.php",
            "@test:stats"
        ],
        "quality:load": "bash scripts/ci/run-k6-load-test.sh",
        "ci": [
            "@lint",
            "@analyse",
            "@validate-config",
            "@validate-openapi",
            "@test",
            "@test:stats:check"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
