    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.19",
    "axios": "^1.6.4",
    "laravel-vite-plugin": "^1.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.1",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.21",
    "@inertiajs/vue3": "^3.0",
    "vue": "^3.4.21"
