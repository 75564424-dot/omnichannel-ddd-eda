{
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/copy-icon-font.mjs",
    "prebuild": "node scripts/copy-icon-font.mjs && node scripts/clear-vite-hot.mjs",
    "build": "vite build",
    "postbuild": "node scripts/clear-vite-hot.mjs",
    "clear-hot": "node scripts/clear-vite-hot.mjs",
    "predev": "node scripts/copy-icon-font.mjs",
    "dev": "node scripts/vite-dev.mjs",
    "prelocal": "node scripts/copy-icon-font.mjs",
    "local": "node scripts/local-dev.mjs",
    "serve": "npm run clear-hot && php artisan serve --host=127.0.0.1 --port=8000",
    "local:build": "npm run build && npm run serve",
    "serve:laravel": "npm run serve",
    "serve:laravel:build": "npm run local:build",
    "test:ui": "playwright test",
    "test:ui:install": "playwright install chromium"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@material-symbols/font-400": "^0.44.10",
