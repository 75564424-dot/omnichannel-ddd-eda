# Playwright local UI tests (template — copy to .env.playwright via npm run instances:env-keys).
# Never commit .env.playwright: APP_KEY is generated locally per machine.

APP_NAME="Platform UI (Playwright)"
APP_ENV=playwright
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=warning

PLATFORM_CLIENT_SLUG=acme-retail
PLATFORM_CLIENT_NAME="Acme Retail Middleware"
PLATFORM_DEPLOYMENT_MODE=instance_per_client
PLATFORM_CONTROL_PLANE=false
PLATFORM_PORTAL_MULTI_TENANT_LOGIN=false
PLATFORM_SEED_INSTANCE_TENANT=true

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

PLATFORM_API_AUTH_ENABLED=false
PLATFORM_WEB_AUTH_ENABLED=true
