APP_NAME="Platform Test"
APP_ENV=testing
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array

PLATFORM_CLIENT_SLUG=platform-test
PLATFORM_CLIENT_NAME="Platform Test"
PLATFORM_DEPLOYMENT_MODE=instance_per_client
PLATFORM_SEED_INSTANCE_TENANT=false
PLATFORM_CONTROL_PLANE=false
PLATFORM_PORTAL_MULTI_TENANT_LOGIN=false
PLATFORM_API_AUTH_ENABLED=false
PLATFORM_WEB_AUTH_ENABLED=false
PLATFORM_SEED_ADMIN_OPERATOR=false
PLATFORM_AUDIT_ENABLED=true
PLATFORM_SIMULATION_ENABLED=false

EVENTBUS_SCHEMA_VALIDATION=false

BCRYPT_ROUNDS=4
