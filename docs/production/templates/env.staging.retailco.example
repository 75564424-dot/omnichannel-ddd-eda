# Staging template — RetailCo simulation rehearsal
# Copy to .env on staging instance. Adjust secrets.

APP_NAME="RetailCo Staging Middleware"
APP_ENV=staging
APP_DEBUG=false
APP_URL=https://retailco-staging.example.com

PLATFORM_CLIENT_SLUG=retailco-staging
PLATFORM_CLIENT_NAME="RetailCo Staging"
PLATFORM_DEPLOYMENT_MODE=instance_per_client
PLATFORM_SEED_INSTANCE_TENANT=true

DB_CONNECTION=mysql
DB_HOST=mysql
DB_DATABASE=platform_retailco_staging
DB_USERNAME=platform
DB_PASSWORD=change-me

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
REDIS_PORT=6379

PLATFORM_API_AUTH_ENABLED=true
PLATFORM_WEB_AUTH_ENABLED=true
PLATFORM_SEED_ADMIN_OPERATOR=true
PLATFORM_ADMIN_EMAIL=admin@staging.local
PLATFORM_ADMIN_PASSWORD=change-me-staging

# Simulation
DEMO_PACK_ENABLED=false

# Apply fixture before first simulation:
# php artisan platform:simulate-client retailco --apply-fixture --events=0 --skip-sync
# php artisan config:clear
# php artisan platform:simulate-client retailco --events=50
